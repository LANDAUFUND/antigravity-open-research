{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://landau.website/schemas/antigravity-public-aggregate-0.1.0.json",
  "title": "СХЕМА ПУБЛИЧНЫХ АГРЕГАТОВ АНТИГРАВИТАЦИИ",
  "description": "Схема для публичных агрегированных данных направления Антигравитация. Схема не фиксирует доказательство антигравитации и предназначена для контролируемого представления серий, отрицательных результатов, метаанализа и параметров без эффекта.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ВЕРСИЯ_СХЕМЫ",
    "СТАТУС_НАУЧНОГО_УТВЕРЖДЕНИЯ",
    "ЛИЦЕНЗИЯ",
    "ЗАПИСИ"
  ],
  "properties": {
    "ВЕРСИЯ_СХЕМЫ": {
      "type": "string",
      "const": "0.1.0"
    },
    "СТАТУС_НАУЧНОГО_УТВЕРЖДЕНИЯ": {
      "type": "string",
      "const": "АНТИГРАВИТАЦИЯ_НЕ_ДОКАЗАНА"
    },
    "КАНОНИЧЕСКАЯ_ФОРМУЛИРОВКА": {
      "type": "string",
      "const": "АНТИГРАВИТАЦИЯ РАССМАТРИВАЕТСЯ КАК ИССЛЕДОВАТЕЛЬСКОЕ НАПРАВЛЕНИЕ, ТРЕБУЮЩЕЕ МАТЕМАТИЧЕСКОЙ ФОРМАЛИЗАЦИИ, ЭКСПЕРИМЕНТАЛЬНОЙ ПРОВЕРКИ, ИЗМЕРИМОСТИ И ВОСПРОИЗВОДИМОСТИ"
    },
    "ЛИЦЕНЗИЯ": {
      "type": "string",
      "enum": [
        "CC_BY_4_0",
        "ВНУТРЕННИЙ_КОНТУР",
        "ТРЕБУЕТ_REVIEW"
      ]
    },
    "ЗАПИСИ": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ID_АГРЕГАТА",
          "ID_СЕРИИ",
          "КАТЕГОРИЯ_РАСЧЕТА",
          "ТИП_СТЕНДА",
          "ИЗМЕРЯЕМАЯ_ВЕЛИЧИНА",
          "ЕДИНИЦА",
          "N",
          "СРЕДНЕЕ",
          "СТАНДАРТНОЕ_ОТКЛОНЕНИЕ",
          "КОНТРОЛЬНЫЙ_РЕЖИМ",
          "ЭФФЕКТ_ОБНАРУЖЕН",
          "СТАТУС_ПУБЛИКАЦИИ",
          "RAW_DATA_STATUS"
        ],
        "properties": {
          "ID_АГРЕГАТА": {
            "type": "string",
            "minLength": 1
          },
          "ID_СЕРИИ": {
            "type": "string",
            "minLength": 1
          },
          "КАТЕГОРИЯ_РАСЧЕТА": {
            "type": "string",
            "enum": [
              "УСТАНОВЛЕННАЯ_ФИЗИКА",
              "ИНЖЕНЕРНАЯ_КОМПЕНСАЦИЯ_ВЕСА",
              "ГИПОТЕТИЧЕСКАЯ_МОДЕЛЬ",
              "СПЕКУЛЯТИВНАЯ_МОДЕЛЬ_ОСОБОЙ_ПРОВЕРКИ"
            ]
          },
          "ТИП_СТЕНДА": {
            "type": "string",
            "minLength": 1
          },
          "ИЗМЕРЯЕМАЯ_ВЕЛИЧИНА": {
            "type": "string",
            "examples": [
              "изменение веса",
              "сила",
              "температура",
              "магнитное поле",
              "ускорение вибрации"
            ]
          },
          "ЕДИНИЦА": {
            "type": "string",
            "minLength": 1
          },
          "N": {
            "type": "integer",
            "minimum": 1
          },
          "СРЕДНЕЕ": {
            "type": "number"
          },
          "СТАНДАРТНОЕ_ОТКЛОНЕНИЕ": {
            "type": "number",
            "minimum": 0
          },
          "ДОВЕРИТЕЛЬНЫЙ_ИНТЕРВАЛ_95": {
            "type": "string",
            "description": "Строка вида [нижняя_граница; верхняя_граница] в той же единице измерения."
          },
          "КОНТРОЛЬНЫЙ_РЕЖИМ": {
            "type": "string",
            "minLength": 1
          },
          "ЭФФЕКТ_ОБНАРУЖЕН": {
            "type": "string",
            "enum": [
              "НЕТ",
              "НЕОПРЕДЕЛЕННО",
              "ТРЕБУЕТ_РЕПЛИКАЦИИ",
              "ПРЕДВАРИТЕЛЬНЫЙ_СИГНАЛ_БЕЗ_СИЛЬНОГО_ВЫВОДА"
            ]
          },
          "СТАТУС_ПУБЛИКАЦИИ": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PUBLIC_CANDIDATE",
              "RELEASE_CANDIDATE",
              "RELEASED",
              "RETRACTED"
            ]
          },
          "RAW_DATA_STATUS": {
            "type": "string",
            "enum": [
              "PUBLIC",
              "CONTROLLED_ACCESS",
              "PRIVATE_PENDING_REVIEW",
              "NOT_COLLECTED",
              "REDACTED"
            ]
          },
          "BITRIX24_FILE_ID": {
            "type": "string",
            "pattern": "^[0-9]+$"
          },
          "GITHUB_PATH": {
            "type": "string"
          },
          "SHA256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "КОММЕНТАРИЙ_ОГРАНИЧЕНИЙ": {
            "type": "string"
          }
        }
      }
    }
  }
}
